<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Detakku" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/darkRed</item>
        <item name="colorPrimaryVariant">@color/darkRed</item>
        <item name="android:colorBackground">@android:color/white</item>
        <item name="actionBarStyle">@style/MyActionBarStyle</item>
        <item name="bottomNavigationStyle">@style/CustomBottomNavigation</item>
    </style>

    <!-- Gaya khusus untuk ActionBar -->
    <style name="MyActionBarStyle" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/white</item>
    </style>

    <style name="Theme.Detakku" parent="Base.Theme.Detakku" />
    <!-- Custom Style untuk BottomNavigationView -->
    <style name="CustomBottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/darkRed</item>
        <item name="itemRippleColor">@android:color/transparent</item>
        <item name="itemActiveIndicatorStyle">@style/NoActiveIndicator</item>

        <item name="itemIconTint">@color/color_nav_item</item>
        <item name="itemTextColor">@color/color_nav_item</item>
    </style>

    <!-- Nonaktifkan indikator aktif (latar putih keunguan) -->
    <style name="NoActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
        <item name="android:shape">rectangle</item>
    </style>
</resources>